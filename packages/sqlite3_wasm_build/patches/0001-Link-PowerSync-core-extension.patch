From 4104d3cac5592cc19f5b37e63d8bb79a5cddcea1 Mon Sep 17 00:00:00 2001
From: Simon Binder <oss@simonbinder.eu>
Date: Wed, 1 Apr 2026 15:50:52 +0200
Subject: [PATCH] Link PowerSync core extension

---
 sqlite3_wasm_build/src/CMakeLists.txt |  6 ++++++
 sqlite3_wasm_build/src/os_web.c       | 12 +++++++++++-
 2 files changed, 17 insertions(+), 1 deletion(-)

diff --git a/sqlite3_wasm_build/src/CMakeLists.txt b/sqlite3_wasm_build/src/CMakeLists.txt
index 52c3df1..bcaeae5 100644
--- a/sqlite3_wasm_build/src/CMakeLists.txt
+++ b/sqlite3_wasm_build/src/CMakeLists.txt
@@ -6,6 +6,7 @@ project(${PROJECT_NAME} LANGUAGES C)
 set(triple wasm32-unknown-wasi)
 set(wasi_sysroot "/usr/share/wasi-sysroot" CACHE PATH "Path to wasi sysroot")
 set(clang "clang" CACHE FILEPATH "Path to wasm-capable clang executable")
+set(POWERSYNC_VERSION "0.4.12" CACHE STRING "PowerSync core version to use")
 
 include(FetchContent)
 
@@ -25,6 +26,9 @@ FetchContent_Declare(
 FetchContent_MakeAvailable(sqlite3)
 FetchContent_MakeAvailable(sqlite3mc)
 
+set(POWERSYNC_A "${CMAKE_BINARY_DIR}/libpowersync-wasm.a")
+file(DOWNLOAD "https://github.com/powersync-ja/powersync-sqlite-core/releases/download/v${POWERSYNC_VERSION}/libpowersync-wasm.a" "${POWERSYNC_A}")
+
 # Generate symbols we need to export from the sqlite3.wasm build
 add_custom_command(
     OUTPUT required_symbols.txt
@@ -64,6 +68,8 @@ macro(base_sqlite3_target name debug crypto)
     list(APPEND sources "${sqlite3_SOURCE_DIR}/sqlite3.c")
   endif()
 
+  list(APPEND sources ${POWERSYNC_A})
+
   if(${debug})
     list(APPEND flags "-g" "-DDEBUG")
   else()
diff --git a/sqlite3_wasm_build/src/os_web.c b/sqlite3_wasm_build/src/os_web.c
index 7a11859..b48960a 100644
--- a/sqlite3_wasm_build/src/os_web.c
+++ b/sqlite3_wasm_build/src/os_web.c
@@ -6,7 +6,17 @@
 #include "bridge.h"
 #include "sqlite3.h"
 
-int sqlite3_os_init(void) { return SQLITE_OK; }
+extern int sqlite3_powersync_init(sqlite3 *db, char **pzErrMsg,
+                                  const sqlite3_api_routines *pApi);
+
+int sqlite3_os_init(void) {
+  int rc = sqlite3_auto_extension((void (*)(void)) &sqlite3_powersync_init);
+  if (rc != SQLITE_OK) {
+    return rc;
+  }
+
+  return SQLITE_OK;
+}
 
 int sqlite3_os_end(void) { return SQLITE_OK; }
 
